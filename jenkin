pipeline {
    agent any

    stages {
        stage('Clone Repository') {
            steps {
                git 'https://github.com/user/myproject.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'npm test'
            }
        }

        stage('Build') {
            steps {
                sh 'npm run build'
            }
        }

        stage('Deploy') {
            steps {
                // Example for copying to a server via SSH
                sshagent(['your-ssh-credential-id']) {
                    sh 'scp -r ./build user@yourserver:/var/www/html'
                }
            }
        }
    }
}
